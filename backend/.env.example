# LazyClip media agent — copy to .env and fill in. Never commit real values.

# ── LLM (OpenAI-compatible) — brainstorm, script, captions ──
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.6-sol

# ── Voice + transcription ──
ELEVENLABS_API_KEY=          # generated voice-over (Generate mode)
WHISPER_API_KEY=             # speech-to-text; WHISPER_BASE_URL defaults to OpenAI
# WHISPER_BASE_URL=https://api.openai.com/v1

# ── Telegram bot (chat gateway) — @Lazy_clip_bot ──
TELEGRAM_BOT_TOKEN=          # from @BotFather; ONE poller per token
TELEGRAM_ADMIN_USER_ID=      # your numeric Telegram user id (allowlist)

# ── Convex (web generation queue: webPoller claims genJobs) ──
CONVEX_URL=https://kindhearted-owl-403.convex.cloud
CONVEX_DEPLOY_KEY=           # prod deploy key for the poller (npx convex deploy-key)

# ── Google Cloud Storage (rendered reels + V4 signed URLs) ──
GCS_BUCKET=conmap-auto-videos
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json   (or VM default service account)

# ── Payments ──
DODO_KEY=                    # Dodo Payments (checkout) — set when account verified

# ── Stock b-roll (both optional; without keys b-roll degrades to a gradient) ──
PEXELS_API_KEY=              # free at pexels.com/api — primary b-roll source
PIXABAY_API_KEY=             # free at pixabay.com/api/docs — fallback b-roll source
# BROLL_CACHE_DIR=           # downloaded footage cache (default: $TMPDIR/reely-broll-cache)

# ── Reframe / ingest tuning ──
# SMART_CROP=0               # disable vision-LLM subject detection (falls back to blur-pad fit)
# VISION_MODEL=              # vision model for subject detection (default: LLM_MODEL)
# YT_MAX_HEIGHT=720          # cap source resolution (default 1080; drop to 720 on throttled IPs)

# ── Reaction stickers (optional; without a key gif overlays are skipped) ──
GIPHY_API_KEY=               # free at developers.giphy.com
# GIF_CACHE_DIR=             # sticker cache (default: $TMPDIR/reely-gif-cache)
