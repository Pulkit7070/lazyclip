# ── Frontend (Vite) — exposed to the browser, safe to be public ──
VITE_CONVEX_URL=            # Convex deployment URL, e.g. https://kindhearted-owl-403.convex.cloud
VITE_CLERK_PUBLISHABLE_KEY= # Clerk publishable key (pk_test_… / pk_live_…)
VITE_POSTHOG_KEY=           # PostHog project key (phc_…)
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Convex CLI (local dev) ──
CONVEX_DEPLOYMENT=          # set by `npx convex dev`
VITE_CONVEX_SITE_URL=       # Convex HTTP actions URL (set by convex)

# ── Server-side secrets (NOT exposed to the browser) ──
CLERK_SECRET_KEY=           # Clerk backend key (sk_…) — server only

# Convex dashboard env vars (set with `npx convex env set <NAME> <val> --prod`):
#   CLERK_JWT_ISSUER_DOMAIN   https://<slug>.clerk.accounts.dev
#   RESEND_API_KEY            re_…               (waitlist welcome email)
#   WAITLIST_FROM             "LazyClip <hello@lazyclip.buzz>"
#   DODO_API_KEY              live checkout (createCheckout)
